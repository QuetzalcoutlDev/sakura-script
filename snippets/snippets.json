{
  "Nueva rama": {
    "prefix": "label",
    "body": [
      "label ${1:Nombre}:",
      "    $0"
    ],
    "description": "Crea una nueva rama de diálogo"
  },
  "Finalizar dialogo": {
    "prefix": "end",
    "body": [
      "$ end()"
    ],
    "description": "Finaliza la ejecución del dialogo"
  },
  "Saltar a otra rama": {
    "prefix": "jump",
    "body": [
      "$ jump(\"${1:label_name}\")"
    ],
    "description": "Inserta un comando de variable"
  },
  "Bloque de Opciones": {
    "prefix": "option",
    "body": [
      "option:",
      "    \"${1:Nombre de la opción}\":",
      "        \"$0\""
    ],
    "description": "Crea un menú de opciones"
  },
  "Condicional if": {
    "prefix": "if",
    "body": [
      "if ${1:variable} == ${2:valor}:",
      "    $0"
    ],
    "description": "Crea un bloque condicional"
  },
  "Cambiar Variable": {
    "prefix": "set",
    "body": [
      "$ set_variable(\"${1:variable}\", ${2:valor})"
    ],
    "description": "Modifica el valor de una variable de juego"
  },
  "Insertar Personaje": {
    "prefix": "[",
    "body": [
      "[${1:Personaje}] \"$0\""
    ],
    "description": "Inserta un personaje y abre comillas para el diálogo"
  }
}