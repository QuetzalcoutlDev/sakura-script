{
  "New branch": {
    "prefix": "label",
    "body": [
      "label ${1:name}:",
      "    $0"
    ],
    "description": "Creates a new dialog branch"
  },
  "End dialog": {
    "prefix": "end",
    "body": [
      "$ end()"
    ],
    "description": "Ends the dialog execution"
  },
  "Jump to another branch": {
    "prefix": "jump",
    "body": [
      "$ jump(\"${1:label_name}\")"
    ],
    "description": "Jump to another branch"
  },
  "Options Block": {
    "prefix": "option",
    "body": [
      "option:",
      "    \"${1:Option name}\":",
      "        \"$0\""
    ],
    "description": "Creates an options menu"
  },
  "If condition": {
    "prefix": "if",
    "body": [
      "if ${1:variable} == ${2:value}:",
      "    $0"
    ],
    "description": "Creates a conditional block"
  },
  "Change Variable": {
    "prefix": "set",
    "body": [
      "$ set_variable(\"${1:variable}\", ${2:value})"
    ],
    "description": "Modifies the value of a game variable"
  },
  "Insert Character": {
    "prefix": "[",
    "body": [
      "[${1:Character}] \"$0\""
    ],
    "description": "Inserts a character and opens quotes for the dialog"
  }
}